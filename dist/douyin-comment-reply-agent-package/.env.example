PORT=8893
HOST=0.0.0.0

# mock | douyin-openapi
COMMENT_ADAPTER=mock

# web | mini
DOUYIN_APP_TYPE=mini
DOUYIN_OPENAPI_BASE=https://open.douyin.com
DOUYIN_APP_ID=
DOUYIN_APP_SECRET=
DOUYIN_ACCESS_TOKEN=
DOUYIN_REFRESH_TOKEN=
DOUYIN_OPEN_ID=

# Required for mobile/web OpenAPI calls.
DOUYIN_ITEM_ID=

# Reply behavior.
REPLY_STYLE=personal-ip
REPLY_REQUIRE_MANUAL_APPROVAL=true

# Optional LLM reply generation. If empty, suggestions fall back to local rules.
LLM_PROVIDER=deepseek
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
LLM_TIMEOUT_MS=20000
LLM_TEMPERATURE=0.55
LLM_MAX_TOKENS=700

# Generic OpenAI-compatible aliases also work.
MODEL_BASE_URL=
MODEL_API_KEY=
MODEL_NAME=
