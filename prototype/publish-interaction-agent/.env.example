PORT=8891
HOST=127.0.0.1

# mock | douyin-openapi
PUBLISH_ADAPTER=mock

# Douyin OpenAPI. Leave empty until platform app and permissions are approved.
DOUYIN_CLIENT_KEY=
DOUYIN_CLIENT_SECRET=
DOUYIN_REDIRECT_URI=
DOUYIN_ACCESS_TOKEN=

# Reply style: personal-ip | customer-service
REPLY_STYLE=personal-ip

# Jimeng research adapter placeholder.
JIMENG_ADAPTER=manual

