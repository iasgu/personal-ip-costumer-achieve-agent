# Alibaba Model Studio / DashScope compatible-mode API.
# Copy this file to .env and fill DASHSCOPE_API_KEY.

PORT=8765
MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_CHAT_PATH=/chat/completions
# Optional. Leave empty to reuse DASHSCOPE_API_KEY.
MODEL_API_KEY=
MODEL_NAME=qwen3.7-plus
MODEL_MULTIMODAL_NAME=qwen3.7-plus
MODEL_VIDEO_NAME=qwen3.7-plus
MODEL_TEMPERATURE=0.7
MODEL_EXTRACT_TEMPERATURE=0.2
MODEL_EXTRACT_MAX_TOKENS=1600
MODEL_REWRITE_MAX_TOKENS=2200

# ASR. qwen3-asr-flash uses DashScope compatible-mode chat/completions with input_audio data URLs.
ASR_PROVIDER=qwen3-asr-flash
ASR_MODEL_NAME=qwen3-asr-flash
QWEN_ASR_MAX_AUDIO_BYTES=7340032
# Optional fallback for OpenAI-compatible Whisper through model-gateway/LiteLLM.
# ASR_BASE_URL=http://127.0.0.1:8787
# ASR_TRANSCRIPT_PATH=/v1/audio/transcriptions
# ASR_API_KEY=replace-with-your-router-key
# ASR_MODEL_NAME=whisper-1
BROWSER_AUDIO_CAPTURE_MS=12000
BROWSER_FRAME_COUNT=5
BROWSER_FRAME_INTERVAL_MS=1600
BROWSER_SEEK_FRAME_SAMPLING=true
BROWSER_FRAME_MAX_SIDE=720
BROWSER_FRAME_JPEG_QUALITY=52

# TTS. qwen-tts is used to generate the driving audio before wan2.7-i2v.
VOICE_PROVIDER=qwen-tts
QWEN_TTS_MODEL=qwen-tts-latest
QWEN_TTS_VOICE=Cherry
QWEN_TTS_MAX_CHARS=580

# DashScope / Alibaba Model Studio assets and avatar video.
# Use a China mainland (Beijing) Model Studio API key for temporary OSS URLs and wan2.7-i2v.
DASHSCOPE_API_KEY=replace-with-dashscope-api-key
DASHSCOPE_API_BASE_URL=https://dashscope.aliyuncs.com
DASHSCOPE_UPLOAD_MODEL=wan2.7-i2v
AVATAR_PROVIDER=wan2.7-i2v
WAN_I2V_MODEL=wan2.7-i2v
# wan2.7-i2v supports integer duration 2-15 seconds.
# The app follows the captured source video duration first; this is only the fallback when source duration is unavailable.
WAN_I2V_DURATION_SECONDS=10
WAN_PROMPT_EXTEND=true
WAN_WATERMARK=false
WAN_S2V_RESOLUTION=720P
WAN_S2V_STYLE=speech
# 0 means submit the async task and return taskId immediately.
WAN_S2V_POLL_TIMEOUT_MS=0
WAN_S2V_POLL_INTERVAL_MS=15000
WAN_PARALLEL_SEGMENTS=true
WAN_MAX_PARALLEL_SEGMENTS=4
